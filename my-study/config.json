{
  "$schema": "https://raw.githubusercontent.com/revisit-studies/study/main/src/parser/StudyConfigSchema.json",
  "studyMetadata": {
    "title": "Combined Study - Demographics & Visualization Literacy",
    "version": "1.0",
    "authors": ["Kosisochukwu Igbokwe"],
    "date": "2026-01-25",
    "description": "A study consisting of a demographic questionnaire and a visualization literacy assessment focused on glucose data.",
    "organizations": ["Interactions Lab", "University of Calgary"]
  },
  "uiConfig": {
    "contactEmail": "kosiso.igbokwe@ucalgary.ca",
    "helpTextPath": "my-study/assets/help.md",
    "logoPath": "revisitAssets/revisitLogoSquare.svg",
    "withProgressBar": true,
    "autoDownloadStudy": false,
    "withSidebar": true,
    "sidebarWidth": 200
  },
  "baseComponents": {
    "glucoseLineChart": {
      "description": "Line chart stimulus for glucose aggregation data ",
      "type": "react-component",
      "path": "my-study/assets/LineChart.tsx",
      "nextButtonLocation": "belowStimulus",
      "instructionLocation": "aboveStimulus",
      "response": []
    },
    "glucoseChartComparison": {
      "description": "Comparison of glucose charts (kept for compatibility, not used)",
      "type": "react-component",
      "path": "my-study/assets/ChartComparison.tsx",
      "nextButtonLocation": "belowStimulus",
      "instructionLocation": "aboveStimulus",
      "response": []
    }
  },
  "importedLibraries": ["mini-vlat"],
  "components": {
    "introduction": {
      "type": "markdown",
      "path": "my-study/assets/introduction.md",
      "response": []
    },
        "visualization-consent": {
      "type": "markdown",
      "path": "my-study/assets/consent.md",
      "response": [
        {
              "id": "participant-name",
              "prompt": "Participant name (please print):",
              "location": "belowStimulus",
              "type": "shortText",
              "placeholder": "Your full name",
              "required": true
            },
            {
              "id": "participant-signature",
              "prompt": "Participant signature:",
              "location": "belowStimulus",
              "type": "shortText",
              "required": true
            },
            {
              "id": "userInitials",
              "prompt": "Please type your initials below to confirm consent for the visualization assessment.",
              "location": "belowStimulus",
              "type": "shortText",
              "placeholder": "Your initials",
              "required": true
            },
            {
              "id": "anonymous-preference",
              "prompt": "I wish to remain anonymous:",
              "location": "belowStimulus",
              "type": "radio",
              "options": [
                "Yes",
                "No"
              ],
              "required": true
            },
            {
              "id": "pseudonym-preference",
              "prompt": "I wish to remain anonymous, but you may refer to me by a pseudonym:",
              "location": "belowStimulus",
              "type": "radio",
              "options": [
                "Yes",
                "No"
              ],
              "required": true
            },
            {
              "id": "pseudonym",
              "prompt": "The pseudonym I chose for myself is:",
              "location": "belowStimulus",
              "type": "shortText",
              "required": false
            },
            {
              "id": "quote-with-name",
              "prompt": "You may quote me and use my name:",
              "location": "belowStimulus",
              "type": "radio",
              "options": [
                "Yes",
                "No"
              ],
              "required": true
            },
            {
              "id": "follow-up-contact",
              "prompt": "You may contact me for a follow-up interview:",
              "location": "belowStimulus",
              "type": "radio",
              "options": [
                "Yes",
                "No"
              ],
              "required": true
            },
            {
              "id": "follow-up-email",
              "prompt": "If yes, please provide an email address where we can reach you:",
              "location": "belowStimulus",
              "type": "shortText",
              "required": false
            }
      ]
    },
    "demographics-personal": {
      "type": "questionnaire",
      "response": [
        {
          "id": "gender-identity",
          "prompt": "What is your gender identity?",
          "required": true,
          "location": "aboveStimulus",
          "type": "radio",
          "options": [
            "Man",
            "Woman",
            "Non-binary",
            "Two Spirit",
            "Prefer not to answer"
          ]
        },
        {
          "id": "age-group",
          "prompt": "What is your age group?",
          "required": true,
          "location": "aboveStimulus",
          "type": "radio",
          "options": [
            "18-25",
            "26-35",
            "36-45",
            "46-56",
            "56-65",
            "66-75",
            "76-85",
            "86+"
          ]
        },
        {
          "id": "education-level",
          "prompt": "What is the highest level of education you have attained?",
          "required": true,
          "location": "aboveStimulus",
          "type": "radio",
          "options": [
            "High school or equivalent",
            "Vocational/technical school (2 year)",
            "Some university",
            "University graduate (4 year)",
            "Master's degree",
            "Doctoral degree (PhD)",
            "Professional degree (MD, JD, etc)",
            "Other"
          ]
        },
        {
          "id": "education-other",
          "prompt": "If other, please specify:",
          "required": false,
          "type": "shortText",
          "location": "aboveStimulus"
        },
        {
          "id": "diabetes-status",
          "prompt": "Which of the following best describes your current diabetes-related health status?",
          "required": true,
          "location": "aboveStimulus",
          "type": "radio",
          "options": [
            "I have been diagnosed as pre-diabetic",
            "I have gestational diabetes",
            "I have Type 1 diabetes",
            "I have Type 2 diabetes",
            "None of the above"
          ]
        },
        {
          "id": "glucose-tracking-methods",
          "prompt": "How do you track your glucose data? (Select all that apply)",
          "required": true,
          "location": "aboveStimulus",
          "type": "checkbox",
          "options": [
            "Continuous Glucose Monitor (CGM)",
            "Blood glucose meter (finger-prick device)",
            "Paper log/notebook",
            "Mobile app",
            "Insulin pump",
            "I do not track my glucose",
            "Other"
          ]
        },
        {
          "id": "glucose-tracking-other",
          "prompt": "If other, please specify:",
          "required": false,
          "type": "shortText",
          "location": "aboveStimulus"
        },
        {
          "id": "glucose-review-frequency",
          "prompt": "How often do you review your glucose data or reports?",
          "required": true,
          "location": "aboveStimulus",
          "type": "radio",
          "options": [
            "Daily",
            "Several times per week",
            "Weekly",
            "Monthly",
            "Rarely",
            "Never"
          ]
        }
      ]
    },

    "diabetes-verification-test": {
      "type": "questionnaire",
      "instruction": "Diabetes Verification Test",
      "instructionLocation": "aboveStimulus",
      "nextButtonLocation": "belowStimulus",
      "response": [
        {
          "id": "diagnosis-category",
          "prompt": "Which of the following best describes your diagnosis?",
          "required": true,
          "location": "aboveStimulus",
          "type": "radio",
          "options": [
            "Type 1 diabetes",
            "Type 2 diabetes",
            "Prediabetes",
            "I do not have diabetes or prediabetes"
          ]
        },
        {
          "id": "insulin-use-frequency",
          "prompt": "Do you currently use insulin?",
          "required": true,
          "location": "aboveStimulus",
          "type": "radio",
          "options": [
            "Yes, every day",
            "Yes, sometimes",
            "No"
          ]
        },
        {
          "id": "glucose-monitor-device",
          "prompt": "Which device do you most often use to monitor your glucose?",
          "required": true,
          "location": "aboveStimulus",
          "type": "radio",
          "options": [
            "Continuous glucose monitor",
            "Fingerstick glucose meter",
            "Both equally",
            "I do not monitor my glucose"
          ]
        }
      ]
    },


    "minivlat-intro": {
      "type": "markdown",
      "path": "my-study/assets/minivlat-intro.md",
      "response": []
    },
    "glucose-intro": {
      "type": "markdown",
      "path": "my-study/assets/glucose-intro.md",
      "response": []
    },
    "glucose-line-001-point-per-day-v1": {
      "baseComponent": "glucoseLineChart",
      "parameters": {
        "dataFile": "./data/glucose_001_point_per_day_v1.csv",
        "title": "Average Glucose (1 point per day - V1)",
        "color": "#4c6ef5",
        "thresholdLow": 3.9,
        "thresholdHigh": 10.0
      },
      "response": [
        {
          "id": "glucose-line-001-point-per-day-v1-likert",
          "prompt": "Please rate your agreement with the following statements.",
          "location": "belowStimulus",
          "type": "matrix-radio",
          "answerOptions": [
            "Strongly Disagree",
            "Disagree",
            "Slightly Disagree",
            "Slightly Agree",
            "Agree",
            "Strongly Agree"
          ],
          "questionOptions": [
            "The visualization transparently includes all important elements of the data",
            "I find it easy to understand this visualization",
            "I would likely use this visualization and its information in my daily life",
            "I would likely share this visualization with my family, friends or on social media",
            "I trust this visualization"
          ],
          "required": true
        }
      ]
    },
